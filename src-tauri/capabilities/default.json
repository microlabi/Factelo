  "windows": [
    "main"
  ],
  "permissions": [
    "core:default",
    "allow-insert-factura",
    "allow-generate-pdf",
    "allow-generar-y-firmar-facturae",
    "allow-verificar-onboarding",
    "allow-obtener-empresas",
    "allow-crear-empresa",
    "allow-obtener-series",
    "allow-crear-serie",
    "allow-obtener-clientes",
    "allow-crear-cliente",
    "allow-update-cliente",
    "allow-delete-cliente",
    "allow-obtener-productos",
    "allow-crear-producto",
    "allow-obtener-dashboard-stats",
    "allow-listar-facturas",
    "allow-obtener-factura-detalle",
    "allow-get-advanced-analytics",
    "allow-get-advanced-statistics",
    "allow-generate-advanced-stats-pdf",
    "allow-generar-qr-legal",
