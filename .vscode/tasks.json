{
	"version": "2.0.0",
	"tasks": [
		{
			"label": "start-vite",
			"type": "shell",
			"command": "npm run dev",
			"isBackground": true,
			"problemMatcher": {
				"owner": "vite",
				"pattern": { "regexp": "." },
				"background": {
					"activeOnStart": true,
					"beginsPattern": "VITE",
					"endsPattern": "Local:"
				}
			}
		},
		{
			"label": "Run app (Vite dev)",
			"type": "shell",
			"command": "npm",
			"args": [
				"run",
				"dev"
			],
			"isBackground": true
		},
		{
			"label": "Run app (Tauri desktop dev)",
			"type": "shell",
			"command": "npm",
			"args": [
				"run",
				"tauri",
				"--",
				"dev"
			],
			"isBackground": true
		},
		{
			"label": "Run app (Tauri desktop dev)",
			"type": "shell",
			"command": "npm",
			"args": [
				"run",
				"tauri",
				"--",
				"dev"
			],
			"isBackground": true
		}
	]
}